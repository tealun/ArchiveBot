# ArchiveBot 环境变量配置示例
# 复制此文件为 .env 并填写真实值

# ====================
# Telegram Bot 配置（必填）
# ====================
# 从 @BotFather 获取
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# 从 @userinfobot 获取你的 Telegram ID
OWNER_ID=0

# ====================
# Telegram 存储频道配置（可选）
# ====================
# 默认存储频道 ID（必填）
CHANNEL_DEFAULT=-1001234567890

# 文档类型分类频道 ID（可选，不配置则使用默认频道）
CHANNEL_TEXT=-1001234567891
CHANNEL_EBOOK=-1001234567892
CHANNEL_DOCUMENT=-1001234567893
CHANNEL_IMAGE=-1001234567894 
CHANNEL_MEDIA=-1001234567895

# 个人直发内容存储频道（可选）
CHANNEL_DIRECT_DEFAULT=-1001234567896

# 来源到频道的映射配置（优先级高于类型映射）请到 config.yaml 中配置
# 标签到频道的映射配置（优先级最高）请到 config.yaml 中配置

# ====================
# AI API 配置（可选）
# ====================

# API 提供商选择（可选，默认为 xai）
AI_API_PROVIDER=xai

# API 密钥（如果使用AI功能）
AI_API_KEY=YOUR_AI_API_KEY_HERE

# API 地址（可选，不填则使用默认值）
AI_API_URL=https://api.x.ai/v1/chat/completions

# 模型名称（可选）
AI_MODEL=grok-4-1-fast-non-reasoning #用于生成回复的快速模型
AI_REASONING_MODEL=grok-4-1-fast-reasoning  # 用于意图分析的推理模型

# AI参考内容排除配置
AI_EXCLUDE_CHANNELS=[]  # 排除的频道 ID 列表，例如：[-1001234567890, -1009876543210]
AI_EXCLUDE_TAGS=[]  # 排除的标签列表，例如：["nsfw", "private"]
# ====================
# 使用说明
# ====================
# 1. 复制此文件为 .env
# 2. 填写真实的 BOT_TOKEN 和 OWNER_ID（必填）
# 3. 填写频道 ID（需要启用Telegram存储时）
# 4. 填写 AI_API_KEY（需要使用AI功能时）
# 5. 将 .env 添加到 .gitignore 以避免泄露敏感信息

# ====================
# 优先级
# ====================
# 环境变量 > config.yaml 配置
# 如果设置了环境变量，将覆盖 config.yaml 中的对应配置
